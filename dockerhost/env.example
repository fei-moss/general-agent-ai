# DockerHost RAG integration defaults. Do not put production credentials here.
APP_PORT=8080
DB_URL=postgresql+asyncpg://postgres:postgres@db:5432/agent
REDIS_URL=redis://cache:6379/0
CELERY_BROKER_URL=redis://cache:6379/1
CELERY_RESULT_BACKEND=redis://cache:6379/2
LLM_PROVIDER=mock
RAG_ENABLED=true
RAG_VECTOR_STORE=pgvector
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=256
# Inject GEMINI_API_KEY with envctl --secret-env GEMINI_API_KEY.
