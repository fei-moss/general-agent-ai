# DockerHost World Cup Chat Server integration defaults. Do not put production credentials here.
APP_PORT=8080
DB_URL=postgresql+asyncpg://postgres:postgres@db:5432/agent
REDIS_URL=redis://cache:6379/0
CELERY_BROKER_URL=redis://cache:6379/1
CELERY_RESULT_BACKEND=redis://cache:6379/2
LLM_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-5.2
ZAI_THINKING_TYPE=enabled
ZAI_REASONING_EFFORT=max
ZAI_TOOL_STREAM=true
RAG_ENABLED=true
RAG_VECTOR_STORE=pgvector
RAG_ADMIN_USER_IDS=
RAG_DEFAULT_KNOWLEDGE_BASE_ID=
RAG_INTERNAL_OWNER_USER_ID=
RAG_ALLOW_CLIENT_KNOWLEDGE_BASE_ID=false
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=256
PROVIDER_DEFAULT_RPM=60
PROVIDER_DEFAULT_TPM=60000
PROVIDER_DEFAULT_MAX_OUTPUT_TOKENS=512
RUN_MAX_RUNTIME_S=300
STREAM_MAXLEN=1000
METRICS_ENABLED=true
REAPER_ENABLED=true
REAPER_INTERVAL_S=30
REAPER_STALE_AFTER_S=300
REAPER_MAX_ATTEMPTS=3
WORKER_POOL=prefork
WORKER_CONCURRENCY=2
# Inject real provider secrets with envctl --secret-env, for example:
#   LLM_PROVIDER=zai envctl up ... --secret-env ZAI_API_KEY --secret-env GEMINI_API_KEY
# For a chat-only GLM smoke without external embeddings, set:
#   RAG_ENABLED=false
#   EMBEDDING_PROVIDER=hash
#   EMBEDDING_MODEL=hash
# For correctness-first smoke fallback, set:
#   WORKER_POOL=solo
#   WORKER_CONCURRENCY=1
