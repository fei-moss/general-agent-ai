# ===== 数据库 / 中间件 =====
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:55432/agent
REDIS_URL=redis://localhost:55379/0

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:55379/1
CELERY_RESULT_BACKEND=redis://localhost:55379/2

# ===== LLM Provider(运行时由 PydanticAI 驱动 agentic loop) =====
# mock | openai | qwen | anthropic | gemini ; 默认 mock 即可零依赖跑通
LLM_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# 通义千问 Qwen(走 DashScope 的 OpenAI 兼容端点)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
DASHSCOPE_API_KEY=
# Google Gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# ===== 运行参数 =====
RATE_LIMIT_PER_MIN=60
MAX_TURNS=10
RETRIEVAL_TOP_K=5
EMBEDDING_DIM=256
REQUEST_TIMEOUT_S=60

# ===== 服务 =====
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
